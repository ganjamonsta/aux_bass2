generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  TELEGRAM_MINI_APP
  TELEGRAM_LOGIN_WIDGET
}

enum SessionLaunchMode {
  TELEGRAM_MINI_APP
  WEB_BROWSER
}

model User {
  id               String            @id @default(cuid())
  displayName      String
  username         String?
  avatarUrl        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  sessions         AuthSession[]
  telegramIdentity TelegramIdentity?
}

model TelegramIdentity {
  id                  String       @id @default(cuid())
  userId              String       @unique
  telegramUserId      String       @unique
  firstName           String
  lastName            String?
  username            String?
  photoUrl            String?
  languageCode        String?
  isPremium           Boolean      @default(false)
  lastAuthenticatedAt DateTime
  lastAuthProvider    AuthProvider
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthSession {
  id           String            @id @default(cuid())
  userId       String
  tokenId      String            @unique
  authProvider AuthProvider
  launchMode   SessionLaunchMode
  issuedAt     DateTime
  expiresAt    DateTime
  revokedAt    DateTime?
  lastSeenAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
}